# MongoDB
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/seubanco?retryWrites=true&w=majority&appName=Cluster0

# NextAuth
NEXTAUTH_URL=https://seu-dominio.com.br/
NEXTAUTH_SECRET=gere-um-secret-forte-aqui

# JWT Secret (usando o mesmo valor que NEXTAUTH_SECRET para consistência)
JWT_SECRET=use-o-mesmo-valor-do-nextauth-secret

# Mercado Pago
MP_ACCESS_TOKEN=seu-token-de-producao-do-mercado-pago

# API
NEXT_PUBLIC_API_URL=https://seu-dominio.com.br/

# Porta fixa para o servidor (padrão)
PORT=3000

# Configurações SMTP para envio de e-mails
SMTP_HOST=seu-servidor-smtp.com
SMTP_PORT=587
SMTP_USER=seu-email@dominio.com
SMTP_PASS=sua-senha-ou-token
EMAIL_FROM=Sua Loja <seu-email@dominio.com>

# Chave da API para rotas CRON
CRON_API_KEY=gere-uma-chave-unica-e-forte-aqui

# Configurações do Redis (para produção - armazenamento de tokens revogados)
# Apenas necessário em PRODUÇÃO, em desenvolvimento é usado armazenamento em memória
REDIS_URL=redis://usuario:senha@seu-redis-host:6379
# Alternativa: configuração por partes
#REDIS_HOST=seu-redis-host
#REDIS_PORT=6379
#REDIS_PASSWORD=sua-senha 